# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004
SERVICE_NAME=eventflow-notification-service
LOG_LEVEL=info

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/eventflow_notifications
# Docker: mongodb://mongo:27017/eventflow_notifications
MONGODB_URI=mongodb://localhost:27017/eventflow_notifications

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Must match the secret used by your auth service to sign tokens.
JWT_SECRET=your_jwt_secret_here

# ─── Inter-service ─────────────────────────────────────────────────────────────
# URL of the User Service (used for broadcast to fetch all users)
USER_SERVICE_URL=http://user-service:3001

# ─── SMTP (Gmail, Brevo, etc.) ────────────────────────────────────────────────
# Brevo: https://app.brevo.com → SMTP & API → copy relay host, login, and SMTP key.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_login@smtp-brevo.com
SMTP_PASS=your_smtp_key
# Required for Brevo: verified sender email (must match a sender you verified in Brevo).
# Optional for Gmail: omit to use SMTP_USER as the From address.
SMTP_FROM=noreply@yourdomain.com

# ─── CORS ───────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Mongo Express (optional dev UI) ──────────────────────────────────────────
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASS=secret
